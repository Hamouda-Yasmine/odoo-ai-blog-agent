<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ai_blog" model="ir.module.category">
        <field name="name">AI Blog Agent</field>
        <field name="sequence">100</field>
    </record>

    <record id="res_groups_privilege_ai_blog" model="res.groups.privilege">
        <field name="name">AI Blog Agent</field>
        <field name="category_id" ref="module_category_ai_blog"/>
    </record>

    <record id="group_ai_blog_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_ai_blog"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_ai_blog_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_ai_blog"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_blog_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
