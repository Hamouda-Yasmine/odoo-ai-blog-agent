<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_blog_provider_list" model="ir.ui.view">
        <field name="name">ai.blog.provider.list</field>
        <field name="model">ai.blog.provider</field>
        <field name="arch" type="xml">
            <list string="AI Providers">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_blog_provider_form" model="ir.ui.view">
        <field name="name">ai.blog.provider.form</field>
        <field name="model">ai.blog.provider</field>
        <field name="arch" type="xml">
            <form string="AI Provider">
                <header>
                    <button name="action_test_connection" string="Test Connection"
                            type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Provider name…"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="api_url" placeholder="https://…"/>
                            <field name="api_key" widget="password"/>
                            <field name="model" placeholder="e.g. gpt-4o-mini"/>
                        </group>
                        <group>
                            <field name="is_default"/>
                            <field name="supports_web_search"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Headers">
                            <field name="request_headers"
                                   placeholder='{"Authorization": "Bearer {api_key}", "Content-Type": "application/json"}'/>
                        </page>
                        <page string="Request Body">
                            <field name="request_body_template"
                                   placeholder='{"model": "{model}", "messages": [{"role": "user", "content": "{prompt}"}], "max_tokens": {max_tokens}}'/>
                        </page>
                        <page string="Response">
                            <group>
                                <field name="response_path"
                                       placeholder="e.g. choices.0.message.content"/>
                            </group>
                        </page>
                        <page string="Web Search" invisible="not supports_web_search">
                            <field name="search_tool_payload"
                                   placeholder='{"tools": [{"google_search": {}}]}'/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_blog_provider_list" model="ir.actions.act_window">
        <field name="name">AI Providers</field>
        <field name="res_model">ai.blog.provider</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
