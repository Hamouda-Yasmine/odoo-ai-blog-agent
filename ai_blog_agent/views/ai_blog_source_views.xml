<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_blog_source_list" model="ir.ui.view">
        <field name="name">ai.blog.source.list</field>
        <field name="model">ai.blog.source</field>
        <field name="arch" type="xml">
            <list string="News Sources">
                <field name="name"/>
                <field name="source_type"/>
                <field name="active"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_ai_blog_source_form" model="ir.ui.view">
        <field name="name">ai.blog.source.form</field>
        <field name="model">ai.blog.source</field>
        <field name="arch" type="xml">
            <form string="News Source">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Source name…"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="source_type"/>
                            <field name="url" placeholder="https://…{keyword}…{language}…"/>
                            <field name="api_key" widget="password"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="REST API Config" invisible="source_type != 'rest_api'">
                            <group>
                                <field name="request_headers"
                                       placeholder='{"Authorization": "Bearer {api_key}"}'/>
                                <field name="response_path" placeholder="e.g. articles"/>
                                <field name="title_path" placeholder="e.g. title"/>
                                <field name="source_name_path" placeholder="e.g. source.name"/>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description" placeholder="Notes about this source…"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_blog_source_list" model="ir.actions.act_window">
        <field name="name">News Sources</field>
        <field name="res_model">ai.blog.source</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
